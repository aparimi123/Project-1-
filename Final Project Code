    "\n",
    "# Wrap each model in a pipeline with preprocessing.\n",
    "pipelines = {\n",
    "    name: Pipeline(steps=[\n",
    "        (\"preprocessor\", preprocessor),\n",
    "        (\"model\", model)\n",
    "    ])\n",
    "    for name, model in models.items()\n",
    "}"
