    ")\n",
    "\n",
    "# -----------------------------\n",
    "# 1. Load the dataset\n",
    "# -----------------------------\n",
    "# NOTE: This file is the shortened CMPD incidents data provided.\n",
    "file_path = \"CMPD_Incidents(Shorter).csv\"\n",
